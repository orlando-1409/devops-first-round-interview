{
  "name": "Audience Builder (Python 3.11)",
  "image": "mcr.microsoft.com/devcontainers/python:1-3.11-bullseye",
  "features": {
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },
  "postCreateCommand": "pip install --upgrade pip && pip install -r requirements-dev.txt",
  "forwardPorts": [8000],
  "portsAttributes": {
    "8000": {
      "label": "Audience Builder API",
      "onAutoForward": "notify"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "charliermarsh.ruff",
        "github.vscode-github-actions"
      ],
      "unwantedRecommendations": [
        "github.copilot",
        "github.copilot-chat"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "python.testing.pytestEnabled": true,

        "ruff.importStrategy": "fromEnvironment",
        "ruff.path": ["/usr/local/bin/ruff"],
        "ruff.nativeServer": "on",
        "ruff.lint.run": "never",

        "github.copilot.enable": {
          "*": false,
          "plaintext": false,
          "markdown": false,
          "python": false,
          "yaml": false,
          "json": false,
          "jsonc": false,
          "toml": false
        },
        "github.copilot.editor.enableAutoCompletions": false,
        "github.copilot.nextEditSuggestions.enabled": false,
        "github.copilot.chat.enabled": false,
        "github.copilot.chat.welcomeMessage": "never",

        "editor.inlineSuggest.enabled": false,
        "editor.inlineSuggest.showToolbar": "never",
        "editor.suggest.preview": false,
        "inlineChat.enabled": false,

        "chat.commandCenter.enabled": false,
        "chat.experimental.statusIndicator.enabled": false,
        "chat.commandPalette.enabled": false,
        "workbench.editor.empty.hint": "hidden",
        "workbench.secondarySideBar.defaultVisibility": "hidden"
      }
    }
  }
}
